# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/flashcard_db
# DATABASE_SSL_CA=         # PEM CA cert for TLS (managed Postgres providers)

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ACCESS_JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
REFRESH_JWT_SECRET=replace-with-a-different-long-random-secret-min-32-chars

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=FlashCard
NEXT_PUBLIC_SITE_URL=http://localhost:3000    # set to https://flashcardai.app in production

# ── Email (OTP + transactional) ────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_SECURE=false        # set to true for port 465 SSL
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FlashcardAI" <noreply@flashcardai.app>

# ── AI ─────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...    # primary — routes to Claude / Gemini
OPENAI_API_KEY=sk-...           # used for PDF image extraction (vision)
# GROQ_API_KEY=gsk_...          # fast text-to-cards fallback (optional)
# DAILY_REVIEW_LIMIT=50         # max due cards per day per user (0 = unlimited)

# ── Payments ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin dashboard ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin            # password is set separately via the admin setup route

# ── Error monitoring ───────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Vercel (CI/CD — set in GitHub Secrets, not here) ──────────────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
