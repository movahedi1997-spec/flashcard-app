# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/flashcard_db

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ACCESS_JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
REFRESH_JWT_SECRET=replace-with-a-different-long-random-secret-min-32-chars

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=FlashCard

# ── AI (Phase 3) ──────────────────────────────────────────────────────────────
# OpenAI API key for PDF → Flashcard generation
OPENAI_API_KEY=sk-...

# ── Payments (Phase 3) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Error monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Vercel (CI/CD — set in GitHub Secrets, not in .env.local) ────────────────
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
